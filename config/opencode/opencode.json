{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": ""
      },
      "models": {
        "gemma-4-12B-it-4bit": {
          "name": "gemma-4-12B-it-4bit",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "attachment": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.6-sol",
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-sol",
      "variant": "low"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "variant": "low"
    }
  },
  "lsp": true,
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": {}
    }
  }
}
