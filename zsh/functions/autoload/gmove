#!/usr/bin/env zsh
# Move staged changes to a new branch
gmove() {
  # Validate required argument
  if [[ -z "$1" ]]; then
    echo "Error: gmove requires a branch name" >&2
    echo "Usage: gmove <new-branch-name> [starting-point]" >&2
    return 1
  fi

  git stash -- $(git diff --staged --name-only) &&
  git add -A &&
  { [[ -z "$(git ls-files --deleted)" ]] || git rm $(git ls-files --deleted) 2>/dev/null } &&
  git commit --no-verify --no-gpg-sign --message "--wip-- [skip ci]" &&
  git branch $1 $2 &&
  git checkout $1 &&
  git stash pop
}
