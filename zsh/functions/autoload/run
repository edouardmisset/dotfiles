#!/usr/bin/env zsh
# Run scripts: deno task for Deno projects, vite plus (vp run) otherwise.
# vp run already detects the package manager and executes package.json scripts and cache its results.
# Called with no script name, it lists the available scripts/tasks instead.
run() {
  local SCRIPT="$1" IS_SCRIPT

  if [[ -f deno.json ]]; then
    if ! command -v deno &> /dev/null; then
      echo "Error: deno is not installed" >&2
      return 1
    fi

    if [[ -z "$SCRIPT" ]]; then
      echo "Available tasks:" >&2
      list_deno_tasks
      return $?
    fi

    IS_SCRIPT=$(is_script_in_deno_json "$SCRIPT") || return $?
    if [[ "$IS_SCRIPT" == "false" ]]; then
      echo "Error: Task '$SCRIPT' not found in deno.json 🚫" >&2
      echo "Available tasks:" >&2
      list_deno_tasks >&2
      return 1
    fi
    deno task "$@"
    return $?
  fi

  if [[ ! -f package.json ]]; then
    echo "Error: No package.json or deno.json found" >&2
    return 1
  fi

  if ! command -v vp &> /dev/null; then
    echo "Error: vp (Vite+) is not installed. Run './install' or 'brew install vite-plus'." >&2
    return 1
  fi

  # With no script name, `vp run` opens its interactive task picker.
  vp run --cache "$@"
}


